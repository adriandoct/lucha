# DOJOIA ACCESS - Configuración de Variables de Entorno

# URL del proyecto de Supabase (ejemplo: https://xyzabc.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=tu_supabase_project_url

# Clave pública anónima de Supabase (anon public key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_supabase_anon_public_key

# Integración con Mercado Pago (Token de acceso de producción o sandbox)
MERCADOPAGO_ACCESS_TOKEN=tu_access_token_aqui

# URL de la aplicación (usada para las URLs de retorno de Mercado Pago)
NEXT_PUBLIC_APP_URL=http://localhost:3000

